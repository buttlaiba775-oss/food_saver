<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginVertical="6dp"
    app:cardBackgroundColor="#F2E6D6"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <TextView
            android:id="@+id/tvFoodTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_toStartOf="@+id/actionButtonsLayout"
            android:layout_alignParentStart="true"
            android:text="Biryani"
            android:textColor="#7A4F37"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvQuantity"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/tvFoodTitle"
            android:layout_toStartOf="@+id/actionButtonsLayout"
            android:layout_alignParentStart="true"
            android:layout_marginTop="4dp"
            android:text="Servings: 10 people"
            android:textColor="#8A7665"
            android:textSize="13sp" />

        <LinearLayout
            android:id="@+id/actionButtonsLayout"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/ivEditPost"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_marginEnd="12dp"
                android:src="@android:drawable/ic_menu_edit"
                app:tint="#7A4F37"
                android:background="#F2E6D6"
                android:clickable="true"
                android:focusable="true"
                android:contentDescription="Edit Post" />

            <ImageView
                android:id="@+id/ivDeletePost"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@android:drawable/ic_menu_delete"
                app:tint="#FF4444" android:background="#F2E6D6"
                android:clickable="true"
                android:focusable="true"
                android:contentDescription="Delete Post" />

        </LinearLayout>

    </RelativeLayout>
</androidx.cardview.widget.CardView>