<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F2E6D6"
    android:fitsSystemWindows="true">

    <RelativeLayout
        android:id="@+id/topAppBar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="#7A4F37"
        android:paddingHorizontal="16dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="26dp"
            android:layout_height="26dp"
            android:layout_centerVertical="true"
            android:src="@drawable/ic_back_arrow"
            app:tint="#FFFFFF" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="Profile"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold" />
    </RelativeLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/topAppBar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            android:paddingTop="20dp"
            android:paddingBottom="40dp">

            <RelativeLayout
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:layout_marginBottom="12dp">

                <ImageView
                    android:id="@+id/ivProfileImage"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/circle_brown_border"
                    android:padding="20dp"
                    android:src="@drawable/ic_ngo_building_alt"
                    app:tint="#7A4F37" />

            </RelativeLayout>

            <TextView
                android:id="@+id/tvOrganizationName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:text="NGO Name"
                android:textColor="#7A4F37"
                android:textSize="16sp"
                android:textStyle="bold" />

            <!-- Name Field -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginBottom="12dp"
                android:background="@drawable/rounded_white_card"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_profile"
                    app:tint="#7A4F37" />

                <TextView
                    android:id="@+id/tvProfileName"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:text="Name"
                    android:textColor="#7A4F37" />

                <ImageView
                    android:id="@+id/btnEditName"
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:background="#7A4F37"
                    android:src="@android:drawable/ic_menu_edit" />
            </LinearLayout>

            <!-- Registration Number Field (New) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginBottom="12dp"
                android:background="@drawable/rounded_white_card"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_reg_no"
                    app:tint="#7A4F37" />

                <TextView
                    android:id="@+id/tvProfileRegNo"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:text="Registration Number"
                    android:textColor="#7A4F37" />

                <ImageView
                    android:id="@+id/btnEditRegNo"
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:background="#7A4F37"
                    android:src="@android:drawable/ic_menu_edit" />
            </LinearLayout>

            <!-- Email Field -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginBottom="12dp"
                android:background="@drawable/rounded_white_card"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@android:drawable/sym_action_email"
                    app:tint="#7A4F37" />

                <TextView
                    android:id="@+id/tvProfileEmail"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:text="Email"
                    android:textColor="#7A4F37" />

                <ImageView
                    android:id="@+id/btnEditEmail"
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:background="#7A4F37"
                    android:src="@android:drawable/ic_menu_edit" />
            </LinearLayout>

            <!-- Contact Field -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginBottom="12dp"
                android:background="@drawable/rounded_white_card"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@android:drawable/stat_sys_phone_call"
                    app:tint="#7A4F37" />

                <TextView
                    android:id="@+id/tvProfileContact"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:text="Phone Number"
                    android:textColor="#7A4F37" />

                <ImageView
                    android:id="@+id/btnEditContact"
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:background="#7A4F37"
                    android:src="@android:drawable/ic_menu_edit" />
            </LinearLayout>

            <!-- Address Field -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginBottom="12dp"
                android:background="@drawable/rounded_white_card"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_location_pin"
                    app:tint="#7A4F37" />

                <TextView
                    android:id="@+id/tvProfileAddress"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:text="Address"
                    android:textColor="#7A4F37" />

                <ImageView
                    android:id="@+id/btnEditAddress"
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:background="#7A4F37"
                    android:src="@android:drawable/ic_menu_edit" />
            </LinearLayout>

            <Button
                android:id="@+id/btnSaveChanges"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="24dp"
                android:backgroundTint="#7A4F37"
                app:cornerRadius="12dp"
                android:text="Save Changes"
                android:textColor="#FFFFFF" />

            <!-- Transparency Dashboard -->
            <LinearLayout
                android:id="@+id/btnTransparencyDashboard"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginBottom="12dp"
                android:background="@drawable/rounded_white_card"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_dashboard"
                    app:tint="#7A4F37" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:text="Transparency dashboard"
                    android:textColor="#7A4F37" />

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_arrow_forward"
                    app:tint="#7A4F37" />
            </LinearLayout>

            <!-- Logout -->
            <LinearLayout
                android:id="@+id/btnLogOut"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="@drawable/rounded_white_card"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@android:drawable/ic_lock_power_off"
                    app:tint="#FF4444" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:text="Log out"
                    android:textColor="#FF4444" />
            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>